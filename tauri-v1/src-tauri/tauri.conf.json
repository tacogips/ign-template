{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "@ign-var:TAURI_PRODUCT_NAME@",
  "version": "@ign-var:VERSION@",
  "identifier": "@ign-var:TAURI_IDENTIFIER=com.example.app@",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "@ign-var:TAURI_PRODUCT_NAME@",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
